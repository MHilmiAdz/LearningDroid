<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/appborder"
    android:padding="32dp">



    <TextView
        android:id="@+id/tv_title_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/background_service"
        android:textColor="?attr/colorPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btn_start_background_service"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_start_background_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="@string/start2"
        app:layout_constraintTop_toBottomOf="@+id/tv_title_background"
        app:layout_constraintBottom_toTopOf="@+id/tv_title_foreground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_stop_background_service" />

    <Button
        android:id="@+id/btn_stop_background_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/stop"
        android:textColor="#FFFFFF"
        app:backgroundTint="#D32F2F"
        app:layout_constraintTop_toTopOf="@+id/btn_start_background_service"
        app:layout_constraintBottom_toBottomOf="@+id/btn_start_background_service"
        app:layout_constraintStart_toEndOf="@+id/btn_start_background_service"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tv_title_foreground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/foreground_service"
        android:textColor="?attr/colorPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/btn_start_background_service"
        app:layout_constraintBottom_toTopOf="@+id/btn_start_foreground_service"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_start_foreground_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="@string/start2"
        app:layout_constraintTop_toBottomOf="@+id/tv_title_foreground"
        app:layout_constraintBottom_toTopOf="@+id/tv_title_bound"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_stop_foreground_service" />

    <Button
        android:id="@+id/btn_stop_foreground_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/stop"
        android:textColor="#FFFFFF"
        app:backgroundTint="#D32F2F"
        app:layout_constraintTop_toTopOf="@+id/btn_start_foreground_service"
        app:layout_constraintBottom_toBottomOf="@+id/btn_start_foreground_service"
        app:layout_constraintStart_toEndOf="@+id/btn_start_foreground_service"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tv_title_bound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/bound_service"
        android:textColor="?attr/colorPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/btn_start_foreground_service"
        app:layout_constraintBottom_toTopOf="@+id/btn_start_bound_service"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_start_bound_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="@string/start2"
        app:layout_constraintTop_toBottomOf="@+id/tv_title_bound"
        app:layout_constraintBottom_toTopOf="@+id/tv_bound_service_number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_stop_bound_service" />

    <Button
        android:id="@+id/btn_stop_bound_service"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/stop"
        android:textColor="#FFFFFF"
        app:backgroundTint="#D32F2F"
        app:layout_constraintTop_toTopOf="@+id/btn_start_bound_service"
        app:layout_constraintBottom_toBottomOf="@+id/btn_start_bound_service"
        app:layout_constraintStart_toEndOf="@+id/btn_start_bound_service"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tv_bound_service_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:textColor="?attr/colorPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/btn_start_bound_service"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>