<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.RECEIVE_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission
        android:name="android.permission.READ_SMS"
        tools:ignore="SmsAndCallLogPolicy" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"
        tools:ignore="ForegroundServicesPolicy" />

    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".mainmenu.ThemeSwitch"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LearningDroid"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".likesapp.LikesAppActivity"
            android:exported="false" />
        <activity
            android:name=".ticketing.TicketingActivity"
            android:exported="false" />
        <activity
            android:name=".customview.CustomViewActivity"
            android:exported="false" />

        <receiver
            android:name=".alarmmanager.AlarmReceiver"
            android:enabled="true"
            android:exported="true"
            tools:ignore="ExportedReceiver" />

        <activity
            android:name=".alarmmanager.AlarmManagerActivity"
            android:exported="false" />
        <activity
            android:name=".simplenotif.DetailActivity"
            android:exported="false"
            android:parentActivityName=".simplenotif.SimpleNotifActivity" />
        <activity
            android:name=".simplenotif.SimpleNotifActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <receiver
            android:name=".broadcast.SMSReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".broadcast.SMSReceiverActivity"
            android:exported="false" />
        <activity
            android:name=".broadcast.BroadcastActivity"
            android:exported="false" />
        <activity
            android:name=".frost.ChatActivity"
            android:exported="false" />
        <activity
            android:name=".frost.ChatSessionActivity"
            android:exported="false" />
        <activity
            android:name=".notesapp.NoteAddUpdateActivity"
            android:exported="false" />
        <activity
            android:name=".roomnote.ui.main.RoomNotesActivity"
            android:exported="false" />
        <activity
            android:name=".roomnote.ui.insert.RoomNotesUpdateActivity"
            android:exported="false" />
        <activity
            android:name=".notesapp.MyNotesApp"
            android:exported="false" />
        <activity
            android:name=".settingpref.SettingPreferenceActivity"
            android:exported="false" />
        <activity
            android:name=".sharedpref.FormUserPreferenceActivity"
            android:exported="false" />
        <activity
            android:name=".sharedpref.SharedPrefActivity"
            android:exported="false" />
        <activity
            android:name=".fileaccess.ReadWriteActivity"
            android:exported="false" />
        <activity
            android:name=".livedata.LiveDataActivity"
            android:exported="false" />
        <activity
            android:name=".viewmodel.ViewModelActivity"
            android:exported="false" />
        <activity
            android:name=".restoreview.RestoReviewActivity"
            android:exported="false" />
        <activity
            android:name=".apicall.ListQuotesActivity"
            android:exported="false" />
        <activity
            android:name=".apicall.APIQuoteActivity"
            android:exported="false" />
        <activity
            android:name=".asynchronous.AsynchronousActivity"
            android:exported="false" />
        <activity
            android:name=".tablayout.TabLayoutActivity"
            android:exported="false" />
        <activity
            android:name=".bottomnav.BottomNavActivity"
            android:exported="false" />
        <activity
            android:name=".drawer.DrawerActivity"
            android:exported="false" />
        <activity
            android:name=".searchbar.SearchBarActivity"
            android:exported="false" />
        <activity
            android:name=".appbar.MenuActivity"
            android:exported="false" />
        <activity
            android:name=".appbar.AppBarActivity"
            android:exported="false" />
        <activity
            android:name=".navigation.NavProfileActivity"
            android:exported="false" />
        <activity
            android:name=".navigation.NavigationActivity"
            android:exported="false" />
        <activity
            android:name=".datapass.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".fragment.FlexFragments"
            android:exported="false" />
        <activity
            android:name=".recycle.RecycleActivity"
            android:exported="false" />
        <activity
            android:name=".recycle.HeroDetailActivity"
            android:exported="false" />
        <activity
            android:name=".recycle.ScrollingActivity"
            android:exported="false" />
        <activity
            android:name=".datapass.MoveForResultActivity"
            android:exported="false" />
        <activity
            android:name=".datapass.MoveWithObjectActivity"
            android:exported="false" />
        <activity
            android:name=".datapass.MoveWithDataActivity"
            android:exported="false" />
        <activity
            android:name=".datapass.MoveActivity"
            android:exported="false" />
        <activity
            android:name=".mainmenu.MainMenuActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".webview.WebViewActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".services.MyServiceActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".services.MyBackgroundService"
            android:enabled="true"
            android:exported="false" />
        <service
            android:name=".services.MyForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_TYPE"
                android:value="This service is used for learning purposes and demonstrates foreground service." />
        </service>
        <service
            android:name=".services.MyBoundService"
            android:enabled="true"
            android:exported="false" />

        <activity
            android:name=".soundpool.MySoundActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".camera.MyCameraActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".camera.PhotoViewerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name="com.google.android.gms.metadata.ModuleDependencies"
            android:enabled="false"
            android:exported="false"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="com.google.android.gms.metadata.MODULE_DEPENDENCIES" />
            </intent-filter>
            <meta-data android:name="photopicker_activity:0:required" android:value="" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

    </application>
</manifest>